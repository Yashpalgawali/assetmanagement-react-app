    "test": "react-scripts test",
    "eject": "react-scripts eject ",
    "add-webxml": "xcopy public\\WEB-INF build\\WEB-INF /E /I /Y",
    "undeploy": "if exist %TOMCAT_HOME%\\webapps\\appname.war del /Q %TOMCAT_HOME%\\webapps\\assetmanagementrest.war && if exist %TOMCAT_HOME%\\webapps\\assetmanagementrest rmdir /S /Q %TOMCAT_HOME%\\webapps\\assetmanagementrest",
